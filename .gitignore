# ==========================================
# AetherCore - Ultimate .gitignore
# ==========================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual Environments ---
.venv/
venv/
ENV/
env/
.env

# --- C++ / Rust / Compiled Binaries ---
target/
*.o
*.obj
*.dylib
*.dll
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
compile_commands.json

# --- AI / Machine Learning Specific (CRITICAL) ---
# Model weights & checkpoints (Never push heavy files to GitHub)
*.pt
*.pth
*.bin
*.safetensors
*.onnx
*.gguf
*.h5
*.pb
checkpoints/
.checkpoints/
logs/
wandb/
tensorboard/
runs/

# --- Datasets ---
datasets/
*.csv
*.jsonl
*.parquet
*.arrow

# --- IDE & OS ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# --- Testing & Coverage ---
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# --- Jupyter Notebooks ---
.ipynb_checkpoints
*.ipynb
